---
import '../styles/global.css';
import Navbar from '../components/shared/Navbar.astro';
import Footer from '../components/shared/Footer.astro';
import SectionHeader from '../components/shared/SectionHeader.astro';
import Button from '../components/shared/Button.astro';
import PondHero from '../components/home/PondHero';
import MissionCards from '../components/home/MissionCards.astro';
import EventsHighlight from '../components/home/EventsHighlight.astro';
import RDHighlight from '../components/home/RDHighlight.astro';
import SponsorStrip from '../components/home/SponsorStrip.astro';
import EndCard from '../components/home/EndCard.astro';
import site from '../data/site.json';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Quantum Computing Initiative at Khalifa University. Learn quantum. Build quantum. Contribute to the ecosystem."
    />
    <title>Quantum Computing Initiative</title>
  </head>
  <body>
    <Navbar home />
    <main>
      <PondHero client:load />

      <section id="mission" class="py-24">
        <div class="section-shell">
          <SectionHeader
            eyebrow="Our mission"
            title="Our mission"
            copy="QCI exists to make quantum computing accessible, practical, and collaborative. Through events, education, and open-source development, we help students move from first concepts to real contributions."
          />
          <div class="mt-10">
            <MissionCards />
          </div>
        </div>
      </section>

      <EventsHighlight />
      <RDHighlight />

      <section id="contact" class="py-24">
        <div class="section-shell">
          <div class="overflow-hidden rounded-[2rem] border border-cyan-quantum/15 bg-ink/75 p-8 shadow-blue-glow backdrop-blur-xl md:p-12">
            <div class="grid gap-8 lg:grid-cols-[minmax(0,1.75fr)_minmax(0,0.9fr)] lg:items-center">
              <div>
                <p class="text-sm font-semibold uppercase tracking-[0.35em] text-cyan-quantum">Contact us</p>
                <h2 class="mt-4 text-3xl font-semibold text-white sm:text-4xl">Let’s build the future of quantum computing together.</h2>
                <p class="mt-4 max-w-2xl text-slate-300">Partner with us on workshops, research, events, and educational programs that make quantum technology more accessible, collaborative, and impactful.</p>
              </div>
              <div class="flex items-start justify-start lg:justify-end">
                <Button href={`mailto:${site.contactEmail}`} variant="secondary">Contact Us</Button>
              </div>
            </div>
          </div>
        </div>
      </section>

      <SponsorStrip />
      <EndCard />
    </main>
    <Footer />
  </body>
</html>
