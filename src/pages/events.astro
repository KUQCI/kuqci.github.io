---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import Navbar from '../components/shared/Navbar.astro';
import Footer from '../components/shared/Footer.astro';
import CustomCursor from '../components/shared/CustomCursor.astro';
import SectionHeader from '../components/shared/SectionHeader.astro';
import EventsExperience from '../components/events/EventsExperience';
import type { SerializedEvent } from '../components/events/types';

const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const faviconHref = `${basePath}/favicon.ico?v=3`;
const faviconPngHref = `${basePath}/favicon-32x32.png?v=3`;
const appleTouchIconHref = `${basePath}/apple-touch-icon.png?v=3`;
const eventEntries = await getCollection('events');
const events: SerializedEvent[] = eventEntries
  .map((entry) => ({
    slug: entry.slug,
    ...entry.data
  }))
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Browse Quantum Computing Initiative workshops, hackathons, talks, bootcamps, and community sessions."
    />
    <title>Events | QCI</title>
    <link rel="icon" href={faviconHref} sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href={faviconPngHref} />
    <link rel="apple-touch-icon" sizes="180x180" href={appleTouchIconHref} />
  </head>
  <body>
    <Navbar />
    <main class="overflow-x-hidden pt-32" data-events-enter>
      <section class="pb-14">
        <div class="section-shell">
          <SectionHeader
            eyebrow="Events"
            title="Events"
            copy="Workshops, hackathons, showcases, and community sessions for learning and building quantum."
          />
        </div>
      </section>

      <section class="overflow-x-hidden pb-24">
        <div class="section-shell min-w-0">
          <EventsExperience events={events} client:load />
        </div>
      </section>
    </main>
    <Footer />
    <CustomCursor />
  </body>
</html>
