---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import Navbar from '../components/shared/Navbar.astro';
import Footer from '../components/shared/Footer.astro';
import SectionHeader from '../components/shared/SectionHeader.astro';
import Button from '../components/shared/Button.astro';
import RDHero from '../components/rd/RDHero.astro';
import ResearchTrackCard from '../components/rd/ResearchTrackCard.astro';
import ProjectCard from '../components/rd/ProjectCard.astro';
import ContributionPath from '../components/rd/ContributionPath.astro';
import site from '../data/site.json';

const tracks = [
  {
    title: 'Quantum Machine Learning',
    copy: 'Exploring how quantum models outperform classical models.'
  },
  {
    title: 'Quantum Circuit Profiling',
    copy: 'Building tools for quantum circuit research and development.'
  },
  {
    title: 'Quantum Chemistry',
    copy: 'Investigating quantum algorithms for chemical applications.'
  },
];

const projects = await getCollection('projects');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="QCI R&D projects, research tracks, and open-source contribution pathway."
    />
    <title>R&D | QCI</title>
  </head>
  <body>
    <Navbar />
    <main>
      <RDHero />

      <section class="py-20">
        <div class="section-shell">
          <SectionHeader eyebrow="Research" title="Research tracks" />
          <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
            {tracks.map((track, index) => <ResearchTrackCard title={track.title} copy={track.copy} index={index} />)}
          </div>
        </div>
      </section>

      <section class="py-20">
        <div class="section-shell">
          <SectionHeader eyebrow="Open source" title="Open-source projects" />
          <div class="mt-10 grid gap-5 lg:grid-cols-2">
            {projects.map((project) => <ProjectCard project={project.data} />)}
          </div>
        </div>
      </section>

      <section class="py-20">
        <div class="section-shell">
          <SectionHeader eyebrow="Contribution" title="How to contribute" />
          <div class="mt-10">
            <ContributionPath />
          </div>
        </div>
      </section>

      <section class="pb-24">
        <div class="section-shell">
          <div class="rounded-2xl border border-gold-duck/25 bg-surface-2 p-8 shadow-gold-glow md:p-10">
            <p class="mono-label mb-3 text-xs uppercase text-gold-duck">R&D onboarding</p>
            <h2 class="text-3xl font-semibold text-white">Join the R&D team</h2>
            <p class="mt-4 max-w-2xl leading-8 text-slate-300">
              Bring a project idea, pick up a good first issue, or help turn research prototypes into useful tools.
            </p>
            <div class="mt-7 flex flex-col gap-3 sm:flex-row">
              <Button href={site.joinUrl}>Join R&D</Button>
              <Button href={site.githubUrl} variant="secondary" external>Open GitHub</Button>
            </div>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
