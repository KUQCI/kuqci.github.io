---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import Navbar from '../components/shared/Navbar.astro';
import Footer from '../components/shared/Footer.astro';
import CustomCursor from '../components/shared/CustomCursor.astro';
import SectionHeader from '../components/shared/SectionHeader.astro';
import RDHero from '../components/rd/RDHero.astro';
import ResearchTrackCard from '../components/rd/ResearchTrackCard.astro';
import ProjectCard from '../components/rd/ProjectCard.astro';
import ContributionPath from '../components/rd/ContributionPath.astro';

const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const faviconHref = `${basePath}/favicon.ico?v=3`;
const faviconPngHref = `${basePath}/favicon-32x32.png?v=3`;
const appleTouchIconHref = `${basePath}/apple-touch-icon.png?v=3`;

const tracks = [
  {
    title: 'Quantum Machine Learning',
    copy: 'Exploring how quantum models outperform classical models.'
  },
  {
    title: 'Quantum Development Tooling',
    copy: 'Building tools for quantum circuit research and development.'
  },
  {
    title: 'Quantum Chemistry',
    copy: 'Investigating quantum algorithms for chemical applications.'
  },
];

const projectOrder = ['QML-Molecular-Atomization-Energy'];
const projects = (await getCollection('projects')).sort((a, b) => {
  const aIndex = projectOrder.indexOf(a.data.name);
  const bIndex = projectOrder.indexOf(b.data.name);

  if (aIndex !== -1 || bIndex !== -1) {
    return (aIndex === -1 ? projectOrder.length : aIndex) - (bIndex === -1 ? projectOrder.length : bIndex);
  }

  return a.data.name.localeCompare(b.data.name);
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="QCI R&D projects, research tracks, and open-source contribution pathway."
    />
    <title>R&D | QCI</title>
    <link rel="icon" href={faviconHref} sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href={faviconPngHref} />
    <link rel="apple-touch-icon" sizes="180x180" href={appleTouchIconHref} />
    <script is:inline>
      document.documentElement.classList.add('supports-scroll-reveal');
    </script>
  </head>
  <body>
    <Navbar />
    <main>
      <RDHero />

      <section class="py-20">
        <div class="section-shell">
          <div data-scroll-reveal="section">
            <SectionHeader eyebrow="Research" title="Research tracks" />
          </div>
          <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
            {
              tracks.map((track, index) => (
                <div data-scroll-reveal style={`--reveal-delay: ${120 + index * 80}ms`}>
                  <ResearchTrackCard title={track.title} copy={track.copy} index={index} />
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <section class="py-20">
        <div class="section-shell">
          <div data-scroll-reveal="section">
            <SectionHeader eyebrow="Open source" title="Open-source projects" />
          </div>
          <div class="mt-10 grid gap-5 lg:grid-cols-2">
            {
              projects.map((project, index) => (
                <div class="h-full" data-scroll-reveal style={`--reveal-delay: ${120 + index * 80}ms`}>
                  <ProjectCard project={project.data} />
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <section class="py-20">
        <div class="section-shell">
          <div data-scroll-reveal="section">
            <SectionHeader eyebrow="Contribution" title="How to get involved" />
          </div>
          <div class="mt-10" data-scroll-reveal style="--reveal-delay: 120ms">
            <ContributionPath />
          </div>
        </div>
      </section>
    </main>
    <Footer />
    <CustomCursor />
    <script is:inline>
      const revealItems = Array.from(document.querySelectorAll('[data-scroll-reveal]'));
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!('IntersectionObserver' in window) || prefersReducedMotion) {
        revealItems.forEach((item) => item.setAttribute('data-reveal-visible', 'true'));
      } else {
        const revealObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;

              entry.target.setAttribute('data-reveal-visible', 'true');
              observer.unobserve(entry.target);
            });
          },
          {
            rootMargin: '0px 0px -10% 0px',
            threshold: 0.1
          }
        );

        revealItems.forEach((item) => revealObserver.observe(item));
      }
    </script>
  </body>
</html>
