---
import site from '../../data/site.json';
---

<footer class="border-t border-cyan-quantum/10 py-10">
  <div class="section-shell flex flex-col gap-6 text-sm text-slate-400 md:flex-row md:items-center md:justify-between">
    <div>
      <p class="font-semibold text-slate-100">{site.name}</p>
      <p>{site.affiliation}</p>
    </div>
    <nav aria-label="Footer navigation" class="flex flex-wrap gap-4">
      <a class="transition hover:text-gold-duck" href="/#mission">About</a>
      <a class="transition hover:text-gold-duck" href="/events">Events</a>
      <a class="transition hover:text-gold-duck" href="/rd">R&D</a>
      <a class="transition hover:text-gold-duck" href="/#sponsors">Sponsors</a>
      <a class="transition hover:text-gold-duck" href={`mailto:${site.contactEmail}`}>Contact</a>
    </nav>
  </div>
</footer>
