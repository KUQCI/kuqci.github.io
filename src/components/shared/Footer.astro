---
import site from '../../data/site.json';
---

<footer class="border-t border-cyan-quantum/10 py-16">
  <div class="section-shell">
    <div class="grid gap-8 lg:grid-cols-[minmax(220px,1.5fr)_repeat(2,minmax(180px,1fr))]">
      <div class="space-y-6">
        <div class="flex items-center gap-3">
          <img src="/logo.png" alt="{site.shortName} logo" class="h-12 w-12 rounded-full border border-cyan-quantum/20 bg-ink/60 object-cover" />
          <div>
            <p class="text-sm font-semibold text-white">{site.name}</p>
            <p class="text-sm text-slate-500">{site.affiliation}</p>
          </div>
        </div>
        
      </div>

      <div class="space-y-4">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-quantum">Quick Links</p>
        <ul class="space-y-3 text-sm text-slate-400">
          <li><a class="transition hover:text-white" href="/">Home</a></li>
          <li><a class="transition hover:text-white" href="/events">Events</a></li>
          <li><a class="transition hover:text-white" href="/rd">R&D</a></li>
        </ul>
      </div>

      

      <div class="space-y-4">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-cyan-quantum">Contact Us</p>
        <div class="space-y-3 text-sm text-slate-400">
          <a class="flex items-center gap-3 transition hover:text-white" href="mailto:quantuminitiative.ku@gmail.com">
            <span class="inline-flex h-6 w-6 items-center justify-center text-cyan-quantum">✉</span>
            <span>quantuminitiative.ku@gmail.com</span>
          </a>
          <div class="flex items-center gap-3">
            <span class="inline-flex h-6 w-6 items-center justify-center text-cyan-quantum">📍</span>
            <span>Khalifa University Abu Dhabi</span>
          </div>

        </div>
      </div>
    </div>
  </div>
</footer>
  </div>
</footer>
