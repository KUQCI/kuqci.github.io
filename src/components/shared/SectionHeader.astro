---
interface Props {
  eyebrow?: string;
  title: string;
  copy?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, copy, align = 'left' } = Astro.props;
---

<div class:list={['max-w-3xl', align === 'center' && 'mx-auto text-center']}>
  {
    eyebrow && (
      <p class="mono-label mb-3 text-xs font-semibold uppercase text-cyan-quantum/80">
        {eyebrow}
      </p>
    )
  }
  <h2 class="text-3xl font-semibold tracking-normal text-white md:text-5xl">{title}</h2>
  {copy && <p class="mt-5 text-base leading-8 text-slate-300 md:text-lg">{copy}</p>}
</div>
