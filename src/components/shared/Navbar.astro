---
import site from '../../data/site.json';


interface Props {
  home?: boolean;
}

const { home = false } = Astro.props;
const links = [
  { label: 'About', href: home ? '#mission' : '/#mission' },
  { label: 'Events', href: '/events' },
  { label: 'R&D', href: '/rd' },
  { label: 'Sponsors', href: home ? '#sponsors' : '/#sponsors' },
  { label: 'Contact', href: home ? '#contact' : '/#contact' }
];
---

{
  /* Small floating home button removed per request */
}

<header
  data-navbar
  data-home={home ? 'true' : 'false'}
  class:list={[
    'fixed left-0 right-0 top-4 z-40 px-4 transition duration-300',
    home ? 'pointer-events-none -translate-y-3 opacity-0' : 'opacity-100'
  ]}
>
  <div class="mx-auto max-w-6xl rounded-2xl border border-cyan-quantum/20 bg-ink/72 shadow-blue-glow backdrop-blur-xl">
    <nav class="flex items-center justify-between px-4 py-3 md:px-5" aria-label="Primary navigation">
      <a href="/" class="group flex items-center gap-3" aria-label="Quantum Computing Initiative home">
        <img src="/logo.png" alt={`${site.shortName} logo`} class="h-10 w-10 rounded-full border border-cyan-quantum/20 bg-ink/35 object-cover transition group-hover:scale-105" />
        <span class="hidden leading-tight sm:block">
          <span class="block text-sm font-semibold text-white">{site.shortName}</span>
          <span class="mono-label block text-[0.68rem] text-slate-400">{site.affiliation}</span>
        </span>
      </a>

      <div class="hidden items-center gap-7 md:flex">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="relative text-sm font-medium text-slate-300 transition after:absolute after:-bottom-2 after:left-0 after:h-px after:w-0 after:bg-gold-duck after:transition-all hover:text-white hover:after:w-full"
            >
              {link.label}
            </a>
          ))
        }
        <div class="flex items-center gap-3">
          <a href="https://www.instagram.com/quantum.computing_ku?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw==" aria-label="Instagram" target="_blank" rel="noreferrer" class="text-slate-300 transition hover:text-white">
            <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" xmlns="http://www.w3.org/2000/svg">
              <path d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2Zm0 1.5A4.25 4.25 0 0 0 3.5 7.75v8.5A4.25 4.25 0 0 0 7.75 20.5h8.5A4.25 4.25 0 0 0 20.5 16.25v-8.5A4.25 4.25 0 0 0 16.25 3.5h-8.5Zm8.86 2.4a.9.9 0 1 1 0 1.8.9.9 0 0 1 0-1.8ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 1.5a3.5 3.5 0 1 0 0 7 3.5 3.5 0 0 0 0-7Z" />
            </svg>
          </a>
          <a href="https://www.linkedin.com/company/ku-qci/?viewAsMember=true" aria-label="LinkedIn" target="_blank" rel="noreferrer" class="text-slate-300 transition hover:text-white">
            <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" xmlns="http://www.w3.org/2000/svg">
              <path d="M4.98 3.5a2.5 2.5 0 1 1-.01 5.001A2.5 2.5 0 0 1 4.98 3.5ZM3 9h3.96V21H3V9Zm7.5 0h3.79v1.68h.05c.53-1 1.82-2.06 3.74-2.06 4 0 4.75 2.63 4.75 6.05V21h-3.96v-5.12c0-1.22-.02-2.78-1.7-2.78-1.71 0-1.97 1.34-1.97 2.72V21H10.5V9Z" />
            </svg>
          </a>
          <a href={site.githubUrl} aria-label="GitHub" target="_blank" rel="noreferrer" class="text-slate-300 transition hover:text-white">
            <svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48 0-.24-.01-.87-.01-1.7-2.77.6-3.36-1.34-3.36-1.34-.45-1.15-1.1-1.46-1.1-1.46-.9-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.89 1.52 2.34 1.08 2.91.83.09-.65.35-1.08.63-1.33-2.22-.25-4.56-1.11-4.56-4.94 0-1.09.39-1.99 1.03-2.69-.1-.26-.45-1.31.1-2.73 0 0 .84-.27 2.75 1.03A9.56 9.56 0 0 1 12 6.8c.85.003 1.7.11 2.5.32 1.9-1.3 2.74-1.03 2.74-1.03.55 1.42.2 2.47.1 2.73.64.7 1.03 1.6 1.03 2.69 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.86 0 1.34-.01 2.42-.01 2.75 0 .27.18.58.69.48A10 10 0 0 0 12 2Z" />
            </svg>
          </a>
        </div>
      </div>

      <button
        data-menu-button
        class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-cyan-quantum/25 text-slate-100 transition hover:border-gold-duck/60 hover:text-gold-duck md:hidden"
        type="button"
        aria-label="Open navigation menu"
        aria-expanded="false"
      >
        <span aria-hidden="true" class="text-xl">=</span>
      </button>
    </nav>

    <div data-menu class="hidden border-t border-cyan-quantum/10 px-4 pb-4 md:hidden">
      <div class="grid gap-2 pt-3">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="rounded-xl px-3 py-2 text-sm font-medium text-slate-300 transition hover:bg-blue-qci/10 hover:text-gold-duck"
            >
              {link.label}
            </a>
          ))
        }
        <a
          href={site.githubUrl}
          class="rounded-xl px-3 py-2 text-sm font-medium text-cyan-quantum transition hover:bg-blue-qci/10 hover:text-gold-duck"
          target="_blank"
          rel="noreferrer"
        >
          GitHub
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  [data-navbar].navbar-visible {
    pointer-events: auto;
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const navbars = document.querySelectorAll<HTMLElement>('[data-navbar]');

  navbars.forEach((navbar) => {
    const menu = navbar.querySelector<HTMLElement>('[data-menu]');
    const button = navbar.querySelector<HTMLButtonElement>('[data-menu-button]');
    const isHome = navbar.dataset.home === 'true';

    const updateVisibility = () => {
      if (!isHome) {
        navbar.classList.add('navbar-visible');
        return;
      }

      navbar.classList.toggle('navbar-visible', window.scrollY > window.innerHeight * 0.34);
    };

    button?.addEventListener('click', () => {
      const expanded = button.getAttribute('aria-expanded') === 'true';
      button.setAttribute('aria-expanded', String(!expanded));
      button.setAttribute('aria-label', expanded ? 'Open navigation menu' : 'Close navigation menu');
      menu?.classList.toggle('hidden', expanded);
    });

    menu?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        button?.setAttribute('aria-expanded', 'false');
        button?.setAttribute('aria-label', 'Open navigation menu');
        menu.classList.add('hidden');
      });
    });

    updateVisibility();
    window.addEventListener('scroll', updateVisibility, { passive: true });
  });
</script>
