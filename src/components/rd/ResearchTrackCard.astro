---
interface Props {
  title: string;
  copy: string;
  index: number;
}

const { title, copy, index } = Astro.props;
---

<article class="technical-panel rounded-2xl p-6">
  <p class="mono-label mb-8 text-xs text-cyan-quantum/70">track.{String(index + 1).padStart(2, '0')}</p>
  <h3 class="text-xl font-semibold text-white">{title}</h3>
  <p class="mt-4 leading-7 text-slate-300">{copy}</p>
</article>
