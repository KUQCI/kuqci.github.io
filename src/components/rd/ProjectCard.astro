---
interface Props {
  project: {
    name: string;
    repo: string;
    status: string;
    difficulty: string;
    stack: string[];
    researchArea: string;
    githubUrl: string;
    docsUrl?: string;
    demoUrl?: string;
    goodFirstIssues: boolean;
    summary: string;
    contributionNeeds: string[];
  };
}

const { project } = Astro.props;
---

<article class="flex h-full flex-col rounded-2xl border border-cyan-quantum/16 bg-surface/78 p-6 shadow-blue-glow">
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div>
      <h3 class="text-xl font-semibold text-white">{project.name}</h3>
      <p class="mono-label mt-2 text-xs text-cyan-quantum">{project.repo}</p>
    </div>
    <span class="mono-label rounded-full border border-gold-duck/25 px-2.5 py-1 text-[0.65rem] uppercase text-gold-duck">
      {project.status}
    </span>
  </div>

  <p class="mt-5 flex-1 leading-7 text-slate-300">{project.summary}</p>

  <dl class="mt-6 grid gap-3 text-sm text-slate-300">
    <div class="flex justify-between gap-4 border-t border-cyan-quantum/10 pt-3">
      <dt class="text-slate-500">Area</dt>
      <dd class="text-right">{project.researchArea}</dd>
    </div>
    <div class="flex justify-between gap-4 border-t border-cyan-quantum/10 pt-3">
      <dt class="text-slate-500">Difficulty</dt>
      <dd>{project.difficulty}</dd>
    </div>
  </dl>

  <div class="mt-5 flex flex-wrap gap-2">
    {project.stack.map((item) => <span class="mono-label rounded-full bg-blue-qci/10 px-2.5 py-1 text-xs text-cyan-quantum">{item}</span>)}
  </div>

  <div class="mt-5">
    <p class="mono-label mb-2 text-xs uppercase text-slate-500">Contribution needs</p>
    <ul class="space-y-2 text-sm text-slate-300">
      {project.contributionNeeds.map((need) => <li class="flex gap-2"><span class="text-gold-duck">-</span>{need}</li>)}
    </ul>
  </div>

  <div class="mt-6 flex flex-wrap items-center gap-3">
    {
      project.goodFirstIssues && (
        <span class="mono-label rounded-full border border-cyan-quantum/20 px-2.5 py-1 text-xs text-cyan-quantum">
          good first issues
        </span>
      )
    }
    <a class="text-sm font-semibold text-gold-duck transition hover:text-white" href={project.githubUrl} target="_blank" rel="noreferrer">
      GitHub
    </a>
    {project.docsUrl && <a class="text-sm font-semibold text-cyan-quantum transition hover:text-white" href={project.docsUrl} target="_blank" rel="noreferrer">Docs</a>}
    {project.demoUrl && <a class="text-sm font-semibold text-cyan-quantum transition hover:text-white" href={project.demoUrl} target="_blank" rel="noreferrer">Demo</a>}
  </div>
</article>
