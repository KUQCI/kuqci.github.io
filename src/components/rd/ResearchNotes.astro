---
interface Note {
  data: {
    title: string;
    summary: string;
    date?: string;
    tags: string[];
    status?: string;
  };
  slug: string;
}

interface Props {
  notes: Note[];
}

const { notes } = Astro.props;
---

<div class="grid gap-5 md:grid-cols-3">
  {
    notes.map((note) => (
      <article class="rounded-2xl border border-cyan-quantum/16 bg-surface/75 p-6">
        <div class="flex items-start justify-between gap-4">
          <p class="mono-label text-xs text-cyan-quantum">{note.data.date ?? 'undated'}</p>
          {note.data.status && (
            <span class="mono-label rounded-full border border-gold-duck/20 px-2 py-1 text-[0.65rem] uppercase text-gold-duck">
              {note.data.status}
            </span>
          )}
        </div>
        <h3 class="mt-5 text-xl font-semibold text-white">{note.data.title}</h3>
        <p class="mt-4 leading-7 text-slate-300">{note.data.summary}</p>
        <div class="mt-5 flex flex-wrap gap-2">
          {note.data.tags.map((tag) => <span class="mono-label rounded-full bg-blue-qci/10 px-2 py-1 text-xs text-cyan-quantum">{tag}</span>)}
        </div>
      </article>
    ))
  }
</div>
