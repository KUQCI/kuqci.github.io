---
const steps = [
  'Join QCI and share your interests.',
  'Explore the project areas and choose a direction.',
  'Align with the team on a small, well-scoped task.',
  'Build a prototype, note, or software contribution.',
  'Share the result for feedback, publication, or a pull request.'
];
---

<div class="relative">
  <div class="mb-8 overflow-x-auto rounded-2xl border border-cyan-quantum/14 bg-surface/50 p-5">
    <p class="mono-label text-sm leading-7 text-cyan-quantum sm:whitespace-nowrap">
      |0&gt; Join QCI -&gt; Explore -&gt; Scope -&gt; Build -&gt; Share
    </p>
  </div>
  <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-5">
    {
      steps.map((step, index) => (
        <article class="rounded-2xl border border-cyan-quantum/14 bg-surface/70 p-5">
          <p class="mono-label text-xs text-gold-duck">step {index + 1}</p>
          <p class="mt-3 font-medium text-slate-100">{step}</p>
        </article>
      ))
    }
  </div>
</div>
