---
const steps = [
  'Pick a project.',
  'Read the project brief.',
  'Join an R&D onboarding session.',
  'Choose a good first issue.',
  'Build and submit a pull request.',
  'Present your contribution at a QCI showcase.'
];
---

<div class="relative">
  <div class="mb-8 overflow-x-auto rounded-2xl border border-cyan-quantum/14 bg-surface/50 p-5">
    <p class="mono-label whitespace-nowrap text-sm text-cyan-quantum">
      |0&gt; Start -&gt; Explore repo -&gt; Claim issue -&gt; Build -&gt; Pull request -&gt; Showcase
    </p>
  </div>
  <div class="grid gap-4 md:grid-cols-3">
    {
      steps.map((step, index) => (
        <article class="rounded-2xl border border-cyan-quantum/14 bg-surface/70 p-5">
          <p class="mono-label text-xs text-gold-duck">step {index + 1}</p>
          <p class="mt-3 font-medium text-slate-100">{step}</p>
        </article>
      ))
    }
  </div>
</div>
