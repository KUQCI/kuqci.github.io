---
import Button from '../shared/Button.astro';
import SectionHeader from '../shared/SectionHeader.astro';

const previews = [
  {
    repo: 'KUQCI/QML-Molecular-Classification',
    status: 'planning',
    copy: 'Quantum machine learning for molecular data classification with QM7.'
  },
  {
    repo: 'KUQCI/Quantum-Circuit-Visualizer',
    status: 'planning',
    copy: 'A simplified tool for visualizing and analyzing quantum circuits.'
  },
  {
    repo: 'KUQCI/Introduction-to-Practical-Quantum-Computing',
    status: 'planning',
    copy: 'A light introduction to applying quantum computing through software.'
  }
];
---

<section class="py-24">
  <div class="section-shell">
    <div data-scroll-reveal="section">
      <SectionHeader
        eyebrow="R&D"
        title="R&D: contributing to the quantum ecosystem"
        copy="We work on open-source quantum software, technical prototypes, and research-driven projects that contribute to the quantum ecosystem."
      />
    </div>

    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {
        previews.map((preview, index) => (
          <div data-scroll-reveal style={`--reveal-delay: ${120 + index * 90}ms`}>
            <article class="h-full rounded-2xl border border-cyan-quantum/16 bg-surface/80 p-5 shadow-blue-glow">
              <div class="grid grid-cols-[minmax(0,1fr)_auto] items-start gap-4">
                <p class="mono-label min-w-0 break-all text-xs text-cyan-quantum sm:text-sm">{preview.repo}</p>
                <span class="mono-label rounded-full border border-gold-duck/30 px-2.5 py-1 text-[0.65rem] uppercase text-gold-duck">
                  {preview.status}
                </span>
              </div>
              <p class="mt-7 leading-7 text-slate-300">{preview.copy}</p>
              <div class="mt-6 h-px bg-gradient-to-r from-cyan-quantum/0 via-cyan-quantum/35 to-cyan-quantum/0" />
            </article>
          </div>
        ))
      }
    </div>

    <div class="mt-8" data-scroll-reveal style="--reveal-delay: 240ms">
      <Button href="/rd">View R&D Projects -&gt;</Button>
    </div>
  </div>
</section>
