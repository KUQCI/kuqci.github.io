---
import Card from '../shared/Card.astro';

const cards = [
  {
    title: 'Educate',
    copy: 'Teach quantum concepts through beginner-friendly workshops, talks, and technical sessions.'
  },
  {
    title: 'Build',
    copy: 'Develop open-source quantum software, tools, and research prototypes.'
  },
  {
    title: 'Connect',
    copy: 'Create opportunities for students, researchers, contributors, and partners to collaborate.'
  }
];
---

<div class="grid gap-5 md:grid-cols-3">
  {
    cards.map((card, index) => (
      <div data-scroll-reveal style={`--reveal-delay: ${180 + index * 90}ms`}>
        <Card class="h-full">
          <p class="mono-label mb-8 text-xs text-cyan-quantum/70">0{index + 1}</p>
          <h3 class="text-2xl font-semibold text-white">{card.title}</h3>
          <p class="mt-4 leading-7 text-slate-300">{card.copy}</p>
        </Card>
      </div>
    ))
  }
</div>
