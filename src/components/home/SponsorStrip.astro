---
import sponsors from '../../data/sponsors.json';
import SectionHeader from '../shared/SectionHeader.astro';
---

<section id="sponsors" class="py-24">
  <div class="section-shell">
    <SectionHeader eyebrow="Sponsors" title="Supported by" />
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        sponsors.map((sponsor) => (
          <a
            href={sponsor.url ?? '#'}
            target={sponsor.url ? '_blank' : undefined}
            rel={sponsor.url ? 'noreferrer' : undefined}
            class="group flex min-h-32 items-center justify-center rounded-2xl border border-cyan-quantum/12 bg-surface/60 p-6 text-center opacity-65 grayscale transition duration-200 hover:border-gold-duck/35 hover:opacity-100 hover:grayscale-0"
          >
            <div>
              <div
                class="mx-auto mb-4 grid h-12 w-12 place-items-center rounded-2xl border border-blue-qci/30 bg-blue-qci/10 text-sm font-black text-cyan-quantum group-hover:border-gold-duck/40 group-hover:text-gold-duck"
                aria-hidden="true"
              >
                {sponsor.name
                  .split(' ')
                  .map((word) => word[0])
                  .join('')
                  .slice(0, 2)}
              </div>
              <p class="font-semibold text-white">{sponsor.name}</p>
              <p class="mono-label mt-2 text-xs text-slate-500">{sponsor.tier}</p>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
