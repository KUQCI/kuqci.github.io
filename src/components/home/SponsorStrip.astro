---
import sponsors from '../../data/sponsors.json';
import SectionHeader from '../shared/SectionHeader.astro';
---

<section id="sponsors" class="py-24">
  <div class="section-shell">
    <div data-scroll-reveal="section">
      <SectionHeader title="Supported by" />
    </div>
    <div class="mt-8" data-scroll-reveal style="--reveal-delay: 120ms">
      <nav class="mx-auto grid max-w-xl grid-cols-1 items-center gap-6 text-center sm:grid-cols-2">
        {
          sponsors
            .map((sponsor) => (
              <a
                href={sponsor.url ?? '#'}
                target={sponsor.url ? '_blank' : undefined}
                rel={sponsor.url ? 'noreferrer' : undefined}
                class="group text-center transition-colors text-slate-400 hover:text-white"
              >
                <p class="font-semibold text-lg md:text-xl">{sponsor.name}</p>
              </a>
            ))
        }
      </nav>
    </div>
  </div>
</section>
